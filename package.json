{
	"name": "root",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		]
	},
	"packageManager": "bun@1.3.12",
	"scripts": {
		"build": "turbo run build",
		"format": "biome format . --write",
		"lint": "biome check .",
		"lint:fix": "biome check . --fix",
		"clean": "git clean -xdf node_modules",
		"clean:workspace": "turbo run clean"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"turbo": "^2.9.6"
	}
}
